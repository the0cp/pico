# Scan the examples directory using glob.Glob, fs.list and path helpers.

import "fs";
import "glob";
import "path";

var search = glob.Glob();
search.Dir = "examples";
search.Pattern = "**/*.cies";
search.Recursive = true;
search.Exclude = ["data/*"];

var files = fs.list(search);
var count = 0;

print "Cieto source files under examples/:";
for (var file : files) {
    count++;
    print "  ${file} | base=${path.base(file)} | ext=${path.ext(file)}";
}

print "found ${count} .cies files";
