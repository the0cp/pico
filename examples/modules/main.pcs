# Script modules export their globals and are named automatically from the file name.

import "stats.pcs";

var scores = [88, 91, 73, 100, 95, 84];

print "scores: ${scores}";
print "sum: ${stats.sum(scores)}";
print "mean: ${stats.mean(scores)}";
print "min: ${stats.min(scores)}";
print "max: ${stats.max(scores)}";
