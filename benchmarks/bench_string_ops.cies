var total = 0;

for (var i = 0; i < 200000; i++) {
    var s = "cieto-" + i + "-runtime-benchmark";

    total = total + s.len();
    total = total + s.find("runtime");

    var t = s.replace("runtime", "vm");
    total = total + t.len();

    var u = t.sub(2, 12);
    total = total + u.len();
}

if (total == 123456789) {
    print total;
}