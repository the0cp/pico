import "assert.cies";

# List Operations
var list = [1, 2];
list.push(3);

assert.eq(list.size(), 3, "List size after push");
assert.eq(list.pop(), 3, "List pop returns last element");
assert.eq(list.size(), 2, "List size after pop");

# List Bulk Fill
var filled = [0; 5];
assert.eq(filled.size(), 5, "List bulk initialization size");
assert.eq(filled[4], 0, "List bulk initialization value");

# Map Operations
var dict = { 
    "a": 1, 
    10: "ten" 
};

assert.eq(dict["a"], 1, "Map string key access");
assert.eq(dict[10], "ten", "Map integer key access");

dict["new"] = 99;
assert.eq(dict["new"], 99, "Map value assignment");

dict["a"] = 2;
assert.eq(dict["a"], 2, "Map existing key update");

dict[true] = "yes";
assert.eq(dict[true], "yes", "Map bool key access");

dict[null] = "nil";
assert.eq(dict[null], "nil", "Map null key access");

# Iteration
var iterSum = 0;
for (var n : [1, 2, 3]) { 
    iterSum += n; 
}
assert.eq(iterSum, 6, "Foreach iteration over list");
